# Скопируй в .env и заполни значения
# Генерация SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=sqlite+aiosqlite:///./lotos_tour.db
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=["http://localhost:5173","http://localhost:5500","http://127.0.0.1:5500","https://thriving-entremet-a84a1b.netlify.app","https://agile-intuition-production.up.railway.app","null"]

# Google OAuth — получить на console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL фронтенда для редиректа после OAuth
FRONTEND_URL=http://localhost:5173
