# Скопируй в .env и заполни значения
# Генерация SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=sqlite+aiosqlite:///./lotos_tour.db
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENV=production

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Получить на: console.cloud.google.com → APIs & Services → Credentials
# Обязательно добавить в "Authorized redirect URIs":
#   https://agile-intuition-production.up.railway.app/index.html
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── URL фронтенда ─────────────────────────────────────────────────────────────
# Используется как fallback redirect_uri при Google OAuth.
# Должен точно совпадать с доменом, который добавлен в Google Cloud Console.
FRONTEND_URL=https://agile-intuition-production.up.railway.app

# ── CORS ──────────────────────────────────────────────────────────────────────
# Список доменов, с которых браузер шлёт запросы к бэкенду.
# Формат JSON-массива (Railway поддерживает).
CORS_ORIGINS=["https://agile-intuition-production.up.railway.app","https://lotus-tur-production-23c6.up.railway.app"]
